# ========================================
# Django Settings
# ========================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,smartmonitor.ifce.edu.br

# ========================================
# Database Configuration
# ========================================
# SQLite (desenvolvimento)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (produção - descomente e configure)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=smartmonitor_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# ========================================
# JWT Configuration
# ========================================
JWT_ACCESS_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# ========================================
# Superuser Configuration (Docker)
# ========================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# ========================================
# API External Services (futuro)
# ========================================
# BACKEND_API_URL=https://api.smartmonitor.ifce.edu.br
# BACKEND_API_KEY=your-api-key

# ========================================
# Model Repository (futuro)
# ========================================
# MODEL_STORAGE_TYPE=drive  # Options: local, drive, s3, azure
# DRIVE_CREDENTIALS_PATH=/path/to/credentials.json
# DRIVE_FOLDER_ID=your-drive-folder-id

# ========================================
# Model Retraining (futuro)
# ========================================
# RETRAINING_ENABLED=False
# RETRAINING_SCHEDULE=weekly  # daily, weekly, monthly
# DATA_SOURCE_URL=https://data.source.com/api

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=logs/smartmonitor.log

# ========================================
# CORS (se necessário)
# ========================================
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://frontend.smartmonitor.ifce.edu.br

# ========================================
# Rate Limiting (futuro)
# ========================================
# RATE_LIMIT_ENABLED=True
# RATE_LIMIT_PER_MINUTE=60
